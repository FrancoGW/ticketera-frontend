# API URL - Backend endpoint
VITE_API_URL=https://ticketera-backend-rust.vercel.app

# URL pública del frontend (opcional). Si no se define, el enlace del scanner usa la URL que devuelve el backend (FRONTEND_URL).
# Útil solo como fallback cuando el backend no devuelve validatorUrl. En producción conviene tener FRONTEND_URL en el backend.
# VITE_FRONTEND_URL=https://www.getpass.com.ar
